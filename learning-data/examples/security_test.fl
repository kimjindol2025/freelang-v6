// ═══════════════════════════════════════════════════════════════════
// Test 1: Basic Operations
// ═══════════════════════════════════════════════════════════════════
println("[Test 1] Basic Operations")

let a = 10
let b = 20
let sum = a + b
println("Sum: " + sum)

let str = "Hello" + " " + "FreeLang"
println("String: " + str)

// ═══════════════════════════════════════════════════════════════════
// Test 2: Collections
// ═══════════════════════════════════════════════════════════════════
println("\n[Test 2] Collections")

let numbers = [1, 2, 3, 4, 5]
println("Array length: " + numbers.length)
println("First element: " + numbers[0])
println("Last element: " + numbers[4])

// ═══════════════════════════════════════════════════════════════════
// Test 3: Functions & Recursion
// ═══════════════════════════════════════════════════════════════════
println("\n[Test 3] Functions & Recursion")

fn fibonacci(n) {
    if n <= 1 {
        return n
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

let fib10 = fibonacci(10)
println("Fibonacci(10): " + fib10)

fn factorial(n) {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

let fact5 = factorial(5)
println("Factorial(5): " + fact5)

// ═══════════════════════════════════════════════════════════════════
// Test 4: Control Flow
// ═══════════════════════════════════════════════════════════════════
println("\n[Test 4] Control Flow")

let i = 0
let loop_result = ""
while i < 5 {
    loop_result = loop_result + i + ","
    i = i + 1
}
println("Loop result: " + loop_result)

let msg = ""
if 5 > 3 {
    msg = "Greater"
} else {
    msg = "Less"
}
println("If-else: " + msg)

// ═══════════════════════════════════════════════════════════════════
// Test 5: Data Structures
// ═══════════════════════════════════════════════════════════════════
println("\n[Test 5] Data Structures")

let dict = {}
dict.name = "FreeLang"
dict.version = "6.0.0"
dict.tests = 77

println("Dict name: " + dict.name)
println("Dict version: " + dict.version)
println("Dict tests: " + dict.tests)

// ═══════════════════════════════════════════════════════════════════
// Test 6: Math Operations
// ═══════════════════════════════════════════════════════════════════
println("\n[Test 6] Math Operations")

let x = 16
let sqrt_x = sqrt(x)
println("sqrt(16) = " + sqrt_x)

let pow2 = pow(2, 8)
println("2^8 = " + pow2)

let abs_neg = abs(-42)
println("abs(-42) = " + abs_neg)

// ═══════════════════════════════════════════════════════════════════
// Test 7: Closures & Higher-Order Functions
// ═══════════════════════════════════════════════════════════════════
println("\n[Test 7] Closures & Higher-Order Functions")

fn create_multiplier(factor) {
    return fn(x) {
        return x * factor
    }
}

let multiply_by_3 = create_multiplier(3)
let result7 = multiply_by_3(7)
println("multiply_by_3(7) = " + result7)

// ═══════════════════════════════════════════════════════════════════
// Test 8: Array Iteration
// ═══════════════════════════════════════════════════════════════════
println("\n[Test 8] Array Iteration")

let nums = [1, 2, 3, 4, 5]
let sum_total = 0
for num in nums {
    sum_total = sum_total + num
}
println("Sum via loop: " + sum_total)

// ═══════════════════════════════════════════════════════════════════
// Test 9: Nested Objects
// ═══════════════════════════════════════════════════════════════════
println("\n[Test 9] Nested Objects")

let user = {}
user.name = "Alice"
user.age = 30

println("User name: " + user.name)
println("User age: " + user.age)

// ═══════════════════════════════════════════════════════════════════
// Test 10: Complex Logic
// ═══════════════════════════════════════════════════════════════════
println("\n[Test 10] Complex Logic")

fn is_positive(n) {
    if n > 0 {
        return true
    }
    return false
}

let num = 42
if is_positive(num) {
    println("42 is positive")
}

