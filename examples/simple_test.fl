// Simple FreeLang Test

println("Test 1: Basic printing")
println("Hello, FreeLang!")

println("")
println("Test 2: Variables")
let x = 42
println("x = " + x)

println("")
println("Test 3: Arrays")
let arr = [1, 2, 3, 4, 5]
println("Array length: " + arr.length)

println("")
println("Test 4: If statement")
if x > 40 {
    println("x is greater than 40")
}

println("")
println("Test 5: Function")
fn add(a, b) {
    return a + b
}

let result = add(10, 20)
println("add(10, 20) = " + result)

println("")
println("✅ All basic tests passed!")
