// FreeLang v6: Hello World
println("Hello, FreeLang v6!")

// Closure test
fn counter() {
  let c = 0
  return fn() {
    c = c + 1
    return c
  }
}

let inc = counter()
println("Count: " + inc())
println("Count: " + inc())
println("Count: " + inc())

// Fibonacci
fn fib(n) {
  if n <= 1 { return n }
  return fib(n - 1) + fib(n - 2)
}
println("fib(10) = " + fib(10))
